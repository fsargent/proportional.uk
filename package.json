{
	"name": "proportional-uk",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''; lefthook install --reset-hooks-path",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"export:video": "bun scripts/export-video.js",
		"export:video:a": "bun scripts/export-video.js --variant a",
		"export:video:b": "bun scripts/export-video.js --variant b",
		"export:video:info": "bun scripts/export-video.js --info"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.0",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"gsap-video-export": "^2.1.0",
		"lefthook": "^2.1.4",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"typescript": "^5.9.3",
		"vite": "^7.2.6"
	},
	"dependencies": {
		"gsap": "^3.14.2"
	}
}
